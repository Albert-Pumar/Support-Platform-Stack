# ── App ──────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=generate-with-openssl-rand-hex-32
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5433/support_db
SF_DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5433/support_mock

# ── Redis / Celery ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Microsoft Graph API ───────────────────────────────
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
OUTLOOK_MAILBOX=support@yourdomain.com
GRAPH_WEBHOOK_SECRET=any-random-string-you-choose
WEBHOOK_BASE_URL=https://your-ngrok-id.ngrok-free.app

# ── AI ────────────────────────────────────────────────
OPENAI_API_KEY=gsk_your-groq-api-key-here
OPENAI_MODEL=llama-3.3-70b-versatile

# ── Integrations (optional) ───────────────────────────
SENTRY_DSN=https://your-key@sentry.io/your-project-id
POSTHOG_API_KEY=phc_your-posthog-key
POSTHOG_HOST=https://app.posthog.com